{
  "name": "@myek/leave-remote",
  "version": "0.1.0",
  "private": true,
  "description": "Module Federation v2 remote build artifact for the MyEK leave mini-app.",
  "scripts": {
    "build:mf": "rspack build --config rspack.config.mjs --env platform=android",
    "build:mf:ios": "rspack build --config rspack.config.mjs --env platform=ios",
    "start": "react-native start --port 9001 --host 0.0.0.0 --platform ios",
    "start:android": "react-native start --port 9001 --host 0.0.0.0 --platform android"
  },
  "dependencies": {
    "@myek/leave": "*"
  },
  "devDependencies": {
    "@myek/sdk": "*",
    "@callstack/repack": "5.2.5",
    "@callstack/repack-plugin-reanimated": "5.2.5",
    "@module-federation/enhanced": "2.3.1",
    "@rspack/cli": "1.7.11",
    "@rspack/core": "1.7.11"
  }
}
