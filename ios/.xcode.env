# This `.xcode.env` file is versioned and is used to source the environment
# used when running script phases inside Xcode.
# To customize your local environment, you can create an `.xcode.env.local`
# file that is not versioned.

# NODE_BINARY variable contains the PATH to the node executable.
#
# Customize the NODE_BINARY variable here.
# For example, to use nvm with brew, add the following line
# . "$(brew --prefix nvm)/nvm.sh" --no-use
export NODE_BINARY=$(command -v node)

# Re.Pack Module Federation v2 + Hermes is incompatible (mirrors enterprise-app).
# Force react-native-xcode.sh to skip hermesc so it doesn't bytecode-compile the
# MF2 bundle. Must match the Podfile (:hermes_enabled => false).
export USE_HERMES=false

# RN 0.81+ ships scripts/bundle.js, a Metro-only bundler that ignores
# react-native.config.js command overrides. This project bundles with Re.Pack
# (react-native.config.js → @callstack/repack/commands/rspack), so point
# react-native-xcode.sh at the RN CLI instead — it reads the config and
# dispatches to Re.Pack's `bundle`. Without this, device/archive builds crash in
# Metro on the MF2 runtime's dynamic import() (TransformError in
# @module-federation/runtime-core). See enterprise-app/ios/.xcode.env.
export CLI_PATH=$REACT_NATIVE_PATH/cli.js
export BUNDLE_COMMAND=bundle
