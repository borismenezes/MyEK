# MyEK environment config
# Copy to .env.local and override per environment.
#
# MyEK now runs against the enterprise-backend behind the Kong edge. Auth mirrors
# enterprise-app: a SINGLE resource-scoped token (`access_as_user`, aud =
# enterprise-app) is acquired by MSAL and attached to every call. All data is
# served by the backend BFF under `/v1/myek/**`. Azure APIM is retired.

# API (Kong edge host; apiClient appends /v1)
API_BASE_URL=https://thon.mohsal.dev
API_DEFAULT_VERSION=v1
API_TIMEOUT_MS=15000
API_MAX_RETRIES=3

# Auth (Microsoft Entra ID / MSAL) — REQUIRED for production sign-in.
#   INTUNE_TENANT_ID  : the Emirates tenant that issues the token (must match
#                       the tenant Kong validates against).
#   INTUNE_CLIENT_ID  : MyEK's app registration (client). Default is the test-
#                       tenant "MyEK" app; set the real Emirates app reg per env.
#                       Set to all-zeros to force the offline MockIntuneAdapter.
#   INTUNE_REDIRECT_URI: must be registered on MyEK's app registration.
#   INTUNE_SCOPE      : the SINGLE token scope. Default already targets the
#                       enterprise-app API audience; override only to add scopes.
INTUNE_TENANT_ID=86ba65bc-68d5-4e44-9445-b2b8a7a64d5a
INTUNE_CLIENT_ID=3122181f-0de3-49fc-9903-c081d7305f22
INTUNE_REDIRECT_URI=msauth.com.myek.app.bm.dev://auth
INTUNE_SCOPE=api://c5bc7a7d-550e-408a-9324-b026a363ddf0/access_as_user

# Backend service client. Points at the same Kong edge as API_BASE_URL. The
# legacy APIM subscription key is gone. API_SCOPE is the same single token scope.
APIM_BASE_URL=https://thon.mohsal.dev
APIM_SUBSCRIPTION_KEY=
API_SCOPE=api://c5bc7a7d-550e-408a-9324-b026a363ddf0/access_as_user

# BFF routes (defaults live in src/config/index.ts — override only to repath).
# Identity comes from the JWT at the edge, so there is no {employeeId} param.
# Implemented on the BFF today:
APIM_PATH_LEAVE=/v1/myek/leave/widget
APIM_PATH_BUSINESS_CARD=/v1/myek/business-card
APIM_PATH_APPRECIATIONS=/v1/myek/appreciations/widget
APIM_PATH_ATTENDANCE=/v1/myek/attendance/widget
APIM_PATH_PAYSLIP=/v1/myek/payslip/widget
APIM_PATH_ROSTER=/v1/myek/roster/widget
APIM_PATH_TIMESHEET=/v1/myek/timesheet/widget
APIM_PATH_MY_TRIPS=/v1/myek/my-trips/widget
APIM_PATH_EVENTS=/v1/myek/events/widget
APIM_PATH_DOCUMENTS=/v1/myek/documents/widget
APIM_PATH_PLATINUM_VOUCHERS=/v1/myek/platinum/vouchers
APIM_PATH_PLATINUM_CARD=/v1/myek/platinum/card
# Not yet on the BFF — these 404 and the service falls back to its bundled
# default until the adapter lands (incremental rollout):
APIM_PATH_PROFILE_PICTURE=/v1/myek/profile-picture
APIM_PATH_APPLICATIONS_MANIFEST=/v1/myek/applications
APIM_PATH_LEAVE_DETAILS=/v1/myek/leave/details
APIM_PATH_ATTENDANCE_DETAILS=/v1/myek/attendance/week
APIM_PATH_USER_PROFILE=/v1/myek/user
APIM_PATH_TIMESHEET_DETAILS=/v1/myek/timesheet/details
APIM_PATH_MY_PAYSLIP=/v1/myek/payslip/details

# Feature flags
FF_DARK_MODE=true
FF_OFFLINE_MODE=true
FF_DRAG_AND_DROP=true
FF_BIOMETRIC_LOGIN=true

# Logging
LOG_LEVEL=info
LOG_REMOTE_ENABLED=false
