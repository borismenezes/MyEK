# MyEK environment config
# Copy to .env.local and override per environment

# API
API_BASE_URL=https://api.myek.emirates.com
API_DEFAULT_VERSION=v1
API_TIMEOUT_MS=15000
API_MAX_RETRIES=3

# Auth (Microsoft Entra ID / MSAL)
INTUNE_TENANT_ID=common
INTUNE_CLIENT_ID=00000000-0000-0000-0000-000000000000
INTUNE_REDIRECT_URI=msauth.com.myek.app.bm.dev://auth
# Sign-in scope — keep limited to identity (Graph / OIDC).
INTUNE_SCOPE=User.Read

# APIM (Azure API Management). API_SCOPE is acquired separately at call-time
# (MSAL silent token) so a missing / unconsented API scope can't break login.
APIM_BASE_URL=https://your-tenant.azure-api.net
APIM_SUBSCRIPTION_KEY=replace-with-apim-subscription-key
API_SCOPE=api://00000000-0000-0000-0000-000000000000/.default

# APIM service paths. `{employeeId}` is substituted per request. Defaults
# live in `src/config/index.ts` so the app still boots without these.
APIM_PATH_LEAVE=/your/leave/path/{employeeId}
APIM_PATH_BUSINESS_CARD=/your/businessCard/path/{employeeId}
APIM_PATH_APPRECIATIONS=/your/appreciations/path/{employeeId}
APIM_PATH_ATTENDANCE=/your/attendance/path/{employeeId}
APIM_PATH_PAYSLIP=/your/payslip/path/{employeeId}
APIM_PATH_ROSTER=/your/roster/path/{employeeId}
APIM_PATH_TIMESHEET=/your/timesheet/path/{employeeId}
APIM_PATH_MY_TRIPS=/your/myTrips/path/{employeeId}
APIM_PATH_EVENTS=/your/events/path/{employeeId}
APIM_PATH_PROFILE_PICTURE=/your/profilePicture/path/{employeeId}
APIM_PATH_APPLICATIONS_MANIFEST=/your/applicationsManifest/path/{employeeId}
APIM_PATH_DOCUMENTS=/your/documents/path/{employeeId}
APIM_PATH_LEAVE_DETAILS=/your/leaveDetails/path/{employeeId}
APIM_PATH_PLATINUM_VOUCHERS=/your/platinumVouchers/path
APIM_PATH_ATTENDANCE_DETAILS=/your/attendanceWeekDetails/path/{employeeId}
APIM_PATH_USER_PROFILE=/your/userProfile/path/{employeeId}
APIM_PATH_TIMESHEET_DETAILS=/your/timesheetDetails/path/{employeeId}
APIM_PATH_MY_PAYSLIP=/your/myPayslip/path/{employeeId}
APIM_PATH_PLATINUM_CARD=/your/platinumCard/path

# Feature flags
FF_DARK_MODE=true
FF_OFFLINE_MODE=true
FF_DRAG_AND_DROP=true
FF_BIOMETRIC_LOGIN=true

# Logging
LOG_LEVEL=info
LOG_REMOTE_ENABLED=false
